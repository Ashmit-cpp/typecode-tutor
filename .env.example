# Clerk Authentication
# Get these values from your Clerk Dashboard: https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Convex Backend
# Get this from your Convex Dashboard: https://dashboard.convex.dev/
VITE_CONVEX_URL=https://your-convex-url.convex.cloud
CONVEX_DEPLOYMENT=your_convex_deployment_name

# Clerk JWT Issuer Domain for Convex Auth
# This should match your Clerk application domain
# Format: https://your-app-domain.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-app-domain.clerk.accounts.dev
VITE_CLERK_JWT_ISSUER_DOMAIN=https://your-app-domain.clerk.accounts.dev

# Optional: Development/Production Environment
NODE_ENV=development
